## Solution-wide ignores for the .NET API and Python LPR service.

# Build output
[Dd]ebug/
[Rr]elease/
x64/
x86/
bin/
obj/

# .NET / Visual Studio local state
.vs/
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.cache
*.pdb
*.pidb
*.svclog

# Local SDK / package caches
.nuget/
packages/
*.nuget.props
*.nuget.targets
**/.dotnet/

# Environment-specific config
.env
.env.local
.env.*.local
appsettings.Development.json

# Python caches / virtual environments
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
.venv/
venv/
env/

